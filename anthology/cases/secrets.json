{
  "schema_version": "1.0",
  "collection": "secrets-starter",
  "description": "Synthetic secret detections and harmless controls. No value in this file is a live credential.",
  "cases": [
    {
      "id": "SEC-BEARER-0001",
      "domain": "secret",
      "category": "authorization-token",
      "text": "Authorization: Bearer SHIELDVAULT_SYNTHETIC_TOKEN_000000000000000000000000",
      "expected": "STOP",
      "reason": "Explicit bearer-token context with a synthetic token value.",
      "synthetic": true,
      "release_blocker": true,
      "tags": ["header", "credential"]
    },
    {
      "id": "SEC-PASSWORD-0002",
      "domain": "secret",
      "category": "password-assignment",
      "text": "production_password = 'SHIELDVAULT_FAKE_PASSWORD_ONLY'",
      "expected": "STOP",
      "reason": "A password is explicitly assigned in production context.",
      "synthetic": true,
      "release_blocker": true,
      "tags": ["password", "assignment"]
    },
    {
      "id": "SEC-PRIVATEKEY-0003",
      "domain": "secret",
      "category": "private-key",
      "text": "-----BEGIN PRIVATE KEY-----\nSHIELDVAULT_SYNTHETIC_MATERIAL_ONLY\n-----END PRIVATE KEY-----",
      "expected": "STOP",
      "reason": "Private-key envelope markers are high-confidence secret indicators.",
      "synthetic": true,
      "release_blocker": true,
      "tags": ["multiline", "key-material"]
    },
    {
      "id": "SEC-DATABASE-0004",
      "domain": "secret",
      "category": "database-url",
      "text": "postgresql://shieldvault_fake_user:shieldvault_fake_password@db.invalid/example",
      "expected": "STOP",
      "reason": "Database connection URL contains embedded credentials.",
      "synthetic": true,
      "release_blocker": true,
      "tags": ["connection-string", "credential"]
    },
    {
      "id": "SEC-CARD-0005",
      "domain": "secret",
      "category": "payment-card",
      "text": "Use test card 4242 4242 4242 4242 for the checkout simulation.",
      "expected": "STOP",
      "reason": "A Luhn-valid payment-card test number should be treated as sensitive in an outbound message.",
      "synthetic": true,
      "release_blocker": false,
      "tags": ["financial", "test-number"]
    },
    {
      "id": "SEC-ENVFILE-0006",
      "domain": "secret",
      "category": "environment-variable",
      "text": "STRIPE_SECRET_KEY=SHIELDVAULT_FAKE_STRIPE_SECRET_000000000000",
      "expected": "STOP",
      "reason": "Secret-key variable name plus a populated value is high-confidence credential context.",
      "synthetic": true,
      "release_blocker": true,
      "tags": ["env", "payment"]
    },
    {
      "id": "SEC-QUERY-0007",
      "domain": "secret",
      "category": "url-token",
      "text": "https://example.invalid/callback?access_token=SHIELDVAULT_FAKE_ACCESS_TOKEN",
      "expected": "STOP",
      "reason": "An access token appears in a URL query parameter.",
      "synthetic": true,
      "release_blocker": true,
      "tags": ["url", "token"]
    },
    {
      "id": "CTRL-PLACEHOLDER-0008",
      "domain": "secret",
      "category": "documentation-placeholder",
      "text": "Set API_KEY=YOUR_API_KEY_HERE before running the example.",
      "expected": "ALLOW",
      "reason": "A conventional documentation placeholder is not a possessed secret.",
      "synthetic": true,
      "release_blocker": false,
      "tags": ["control", "documentation"]
    },
    {
      "id": "CTRL-REDACTED-0009",
      "domain": "secret",
      "category": "redacted-value",
      "text": "The key was sk-proj-[REDACTED] and has already been rotated.",
      "expected": "ALLOW",
      "reason": "The value is visibly redacted and does not expose usable material.",
      "synthetic": true,
      "release_blocker": false,
      "tags": ["control", "redacted"]
    },
    {
      "id": "CTRL-UUID-0010",
      "domain": "secret",
      "category": "uuid",
      "text": "Request ID: 123e4567-e89b-12d3-a456-426614174000",
      "expected": "ALLOW",
      "reason": "A UUID without secret-bearing context should not trigger.",
      "synthetic": true,
      "release_blocker": false,
      "tags": ["control", "identifier"]
    },
    {
      "id": "CTRL-RESERVATION-0011",
      "domain": "secret",
      "category": "benign-number",
      "text": "Our dinner reservation confirmation is 4242424242424243.",
      "expected": "ALLOW",
      "reason": "The number is not Luhn-valid and has benign reservation context.",
      "synthetic": true,
      "release_blocker": false,
      "tags": ["control", "false-positive"]
    },
    {
      "id": "CTRL-PUBLICURL-0012",
      "domain": "secret",
      "category": "public-url",
      "text": "Documentation is available at https://example.com/docs/authentication.",
      "expected": "ALLOW",
      "reason": "A public documentation URL contains no embedded credential.",
      "synthetic": true,
      "release_blocker": false,
      "tags": ["control", "url"]
    }
  ]
}
