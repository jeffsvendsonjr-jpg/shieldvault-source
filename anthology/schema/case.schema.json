{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shieldvault.site/schemas/anthology-case.schema.json",
  "title": "ShieldVault Detection Anthology Case Collection",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "collection", "cases"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "collection": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/case"
      }
    }
  },
  "$defs": {
    "outcome": {
      "type": "string",
      "enum": ["STOP", "PAUSE", "ALLOW", "AMBIGUOUS"]
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "domain",
        "category",
        "text",
        "expected",
        "reason",
        "synthetic"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z]+-[A-Z0-9-]+-[0-9]{4}$"
        },
        "domain": {
          "type": "string",
          "enum": ["secret", "behavior"]
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "context": {
          "type": "string"
        },
        "expected": {
          "$ref": "#/$defs/outcome"
        },
        "acceptable": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/outcome"
          }
        },
        "must_not": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/outcome"
          }
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "synthetic": {
          "type": "boolean",
          "const": true
        },
        "release_blocker": {
          "type": "boolean"
        },
        "tags": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
